# Obsidian workspace state (personal layout, not shared)
.obsidian/workspace.json
.obsidian/workspace-mobile.json

# Obsidian cache and temp files
.obsidian/cache
.trash/

# macOS
.DS_Store
**/.DS_Store

# Large media files (store externally, link in notes)
*.mp4
*.mov
*.avi
*.mkv
*.zip
*.dmg

# Plugin binaries (reinstall from community plugins)
.obsidian/plugins/*/main.js
.obsidian/plugins/*/styles.css

# Keep everything else — settings, templates, notes, manifests
